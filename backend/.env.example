# Database (Neon Serverless PostgreSQL)
# Get from: https://console.neon.tech → Connection Details → asyncpg driver
DATABASE_URL=postgresql+asyncpg://neondb_owner:your-password@ep-your-endpoint.us-east-1.aws.neon.tech/neondb?ssl=require

# Application
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_PREFIX=
APP_NAME=ReviewSphere API
APP_VERSION=1.0.0
DEBUG=false

# JWT Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# CORS (add your deployed frontend URL)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://your-frontend.vercel.app"]

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
