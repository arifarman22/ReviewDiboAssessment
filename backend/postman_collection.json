{
  "info": {
    "name": "ReviewSphere API",
    "description": "Complete API collection for the ReviewSphere Product Review Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8000/api"},
    {"key": "token", "value": ""},
    {"key": "adminToken", "value": ""},
    {"key": "userId", "value": ""},
    {"key": "productId", "value": ""},
    {"key": "reviewId", "value": ""}
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {"method": "GET", "url": {"raw": "http://localhost:8000/"}}
        },
        {
          "name": "Health Check",
          "request": {"method": "GET", "url": {"raw": "http://localhost:8000/health"}}
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/auth/register"},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test User\", \"email\": \"test@example.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/auth/login"},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"sarah@example.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/auth/login"},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@reviewsphere.com\", \"password\": \"admin123\"}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/auth/me"},
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/products"}}
        },
        {
          "name": "Get Products with Search",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/products?search=mouse&sort_by=rating"}}
        },
        {
          "name": "Get Products with Rating Filter",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/products?rating=5&page=1&limit=6"}}
        },
        {
          "name": "Get Products Sorted by Reviews",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/products?sort_by=reviews&limit=6"}}
        },
        {
          "name": "Get Product Detail",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/products/{{productId}}"}}
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/products"},
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"New Product\", \"description\": \"A great new product\", \"short_description\": \"Short desc\", \"category\": \"Tech\", \"price\": 99.99, \"image_url\": \"https://picsum.photos/seed/new/800/600\"}"
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "url": {"raw": "{{baseUrl}}/products/{{productId}}"},
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Updated Product Title\", \"price\": 129.99}"
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/products/{{productId}}"},
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/reviews"},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"product_id\": \"{{productId}}\", \"user_id\": \"{{userId}}\", \"rating\": 5, \"comment\": \"This is an amazing product! Highly recommended for everyone.\"}"
            }
          }
        },
        {
          "name": "Get Review",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/reviews/{{reviewId}}"}}
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "url": {"raw": "{{baseUrl}}/reviews/{{reviewId}}"},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"rating\": 4, \"comment\": \"Updated review - still great but found a minor issue.\"}"
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/reviews/{{reviewId}}"}
          }
        }
      ]
    }
  ]
}
